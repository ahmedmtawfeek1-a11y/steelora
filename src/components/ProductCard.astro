---
// ProductCard.astro — Individual product card with WhatsApp CTA, fully localized
interface Props {
  name: string;
  sizeLabel: string;
  description: string;
  features: string[];
  image: string;
  whatsappLink: string;
  orderLabel: string;
}

const { name, sizeLabel, description, features, image, whatsappLink, orderLabel } = Astro.props;
---

<div class="group relative bg-gradient-to-b from-slate-800/80 to-slate-900/80 rounded-2xl overflow-hidden border border-slate-700/50 hover:border-accent/30 transition-all duration-500 hover:shadow-2xl hover:shadow-accent/10">
  <!-- Product Image -->
  <div class="relative overflow-hidden aspect-[4/3]">
    <img
      src={image}
      alt={name}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
      loading="lazy"
    />
    <!-- Size Badge -->
    <div class="absolute top-4 end-4 px-4 py-2 bg-accent/90 backdrop-blur-sm rounded-lg text-white font-bold text-sm shadow-lg">
      {sizeLabel}
    </div>
    <!-- Gradient overlay on hover -->
    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  </div>
  
  <!-- Content -->
  <div class="p-6 sm:p-8 flex flex-col justify-between h-[calc(100%-aspect-[4/3])]">
    <div>
      <!-- Title -->
      <h3 class="text-2xl font-black text-white mb-4">{name}</h3>
      
      <!-- Description -->
      <p class="text-gray-300 leading-relaxed mb-6 text-sm sm:text-base">{description}</p>
      
      <!-- Features -->
      <ul class="space-y-3 mb-8">
        {features.map((feature) => (
          <li class="flex items-center gap-3 text-gray-300 text-sm sm:text-base">
            <div class="flex-shrink-0 w-5 h-5 rounded-full bg-accent/20 flex items-center justify-center">
              <svg class="w-3 h-3 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <span>{feature}</span>
          </li>
        ))}
      </ul>
    </div>
    
    <!-- WhatsApp CTA Button -->
    <a
      href={whatsappLink}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center justify-center gap-3 w-full px-6 py-4 bg-green-600 hover:bg-green-500 text-white font-bold text-base sm:text-lg rounded-xl transition-all duration-300 shadow-lg shadow-green-600/20 hover:shadow-green-500/40 hover:scale-[1.02] active:scale-95"
    >
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span>{orderLabel}</span>
    </a>
  </div>
</div>
