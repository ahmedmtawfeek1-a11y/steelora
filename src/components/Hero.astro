---
// Hero.astro — Full-screen hero section with CTA, fully localized
import { translations, type Lang } from '../utils/i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'ar' } = Astro.props;
const t = translations[lang];

const whatsappMessage = lang === 'ar' 
  ? encodeURIComponent('أود الاستفسار عن شوايات ستيلورا') 
  : encodeURIComponent('Hi Steelora, I am interested in your grills');
const whatsappLink = `https://wa.me/201012345678?text=${whatsappMessage}`;
---

<section id="home" class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background Video — Cinematic, decorative only (fixed: no poster) -->
  <video
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    aria-hidden="true"
    tabindex="-1"
    class="absolute inset-0 z-0 h-full w-full object-cover"
    style="will-change: transform; transform: translate3d(0,0,0);"
  >
    <source src="/herosection.mp4" type="video/mp4" />
  </video>

  <!-- Dark Cinematic Overlay -->
  <div
    class="absolute inset-0 z-[1] pointer-events-none"
    style="background: linear-gradient(180deg, rgba(0,0,0,0.72), rgba(0,0,0,0.55));"
  ></div>
  <!-- Subtle bottom vignette for depth -->
  <div class="absolute inset-0 z-[1] pointer-events-none bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
  
  <!-- Decorative fire particles (CSS only) -->
  <div class="absolute bottom-0 inset-x-0 h-32 bg-gradient-to-t from-accent/10 to-transparent"></div>
  <div class="absolute top-1/4 start-10 w-2 h-2 bg-accent-light rounded-full animate-float opacity-40" style="animation-delay: 0s;"></div>
  <div class="absolute top-1/3 start-1/4 w-1.5 h-1.5 bg-accent rounded-full animate-float opacity-30" style="animation-delay: 0.5s;"></div>
  <div class="absolute top-1/2 start-1/3 w-1 h-1 bg-accent-light rounded-full animate-float opacity-20" style="animation-delay: 1s;"></div>
  
  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-32 w-full">
    <div class="max-w-3xl text-start">
      <!-- Tagline badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-accent/10 border border-accent/20 mb-6 animate-fade-in" style="animation-delay: 0.2s; opacity: 0;">
        <span class="w-2 h-2 bg-accent-light rounded-full animate-pulse-glow"></span>
        <span class="text-accent-light text-sm font-medium">{t.badge}</span>
      </div>
      
      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-white leading-tight mb-6 animate-fade-in-up" style="opacity: 0; animation-delay: 0.3s;">
        {t.titlePart1}
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light"> {t.titlePart2}</span>
        <br />
        <span class="text-3xl sm:text-4xl md:text-5xl lg:text-5xl font-bold text-gray-200">{t.titlePart3}</span>
      </h1>
      
      <!-- Subheadline -->
      <p class="text-lg sm:text-xl text-gray-300 leading-relaxed mb-10 max-w-2xl animate-fade-in-up" style="opacity: 0; animation-delay: 0.5s;">
        {t.heroDesc}
      </p>
      
      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-4 animate-fade-in-up" style="opacity: 0; animation-delay: 0.7s;">
        <a
          href="#products"
          class="group inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-accent to-accent-light text-white font-bold text-lg rounded-xl hover:from-accent-light hover:to-accent transition-all duration-300 shadow-lg shadow-accent/30 hover:shadow-accent-light/50 hover:scale-105"
        >
          <span>{t.heroCta1}</span>
          <svg 
            class={`w-5 h-5 transition-transform duration-300 ${lang === 'ar' ? 'rotate-180 group-hover:-translate-x-1' : 'group-hover:translate-x-1'}`}
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-8 py-4 bg-green-600/20 border border-green-500/40 text-green-400 font-bold text-lg rounded-xl hover:bg-green-600/30 hover:border-green-400/60 transition-all duration-300 hover:scale-105"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span>{t.heroCta2}</span>
        </a>
      </div>
      
      <!-- Trust Indicators -->
      <div class="flex flex-wrap gap-8 mt-12 pt-8 border-t border-white/10 animate-fade-in" style="opacity: 0; animation-delay: 1s;">
        <div class="flex items-center gap-2">
          <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <div>
            <p class="text-white font-bold text-lg">{t.qualityGuarantee}</p>
            <p class="text-gray-400 text-xs">{t.egyptianSteel}</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <div>
            <p class="text-white font-bold text-lg">{t.heatDistribution}</p>
            <p class="text-gray-400 text-xs">{t.preciseEngineering}</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <p class="text-white font-bold text-lg">{t.highDurability}</p>
            <p class="text-gray-400 text-xs">{t.builtToLast}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-accent-light/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<script>
  // Respect prefers-reduced-motion — pause video if enabled
  const heroVideo = document.querySelector('#home video') as HTMLVideoElement | null;
  if (heroVideo) {
    const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    const handleMotion = (e: MediaQueryList | MediaQueryListEvent) => {
      if (e.matches) {
        heroVideo.pause();
      } else {
        heroVideo.play().catch(() => {});
      }
    };
    handleMotion(motionQuery);
    motionQuery.addEventListener('change', handleMotion);
  }
</script>
