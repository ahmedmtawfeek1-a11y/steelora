---
// Products.astro — Products section with two premium grills
import ProductCard from './ProductCard.astro';
---

<section id="products" class="relative py-20 sm:py-28 bg-gradient-to-b from-primary via-slate-900 to-primary overflow-hidden">
  <!-- Decorative background -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-amber-500 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-orange-600 rounded-full blur-3xl"></div>
  </div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-amber-500/10 border border-amber-500/20 rounded-full text-amber-400 text-sm font-medium mb-4">منتجاتنا المميزة</span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-white mb-4">
        شوايات
        <span class="text-transparent bg-clip-text bg-gradient-to-l from-amber-400 to-orange-500">ستيلورا</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        اختر الحجم المناسب لاحتياجاتك — كل شواية مصنوعة بدقة هندسية لتقديم أفضل تجربة شواء
      </p>
      <!-- Decorative line -->
      <div class="mt-6 flex items-center justify-center gap-2">
        <div class="w-12 h-0.5 bg-amber-500/30"></div>
        <div class="w-3 h-3 border-2 border-amber-500 rotate-45"></div>
        <div class="w-12 h-0.5 bg-amber-500/30"></div>
      </div>
    </div>
    
    <!-- Products Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      <ProductCard
        name="شواية ستيلورا (3040)"
        nameEn="Steelora Grill 3040"
        size="3040"
        sizeLabel="30×40 سم"
        description="شواية مدمجة مثالية للتجمعات الصغيرة والعائلية. مصنوعة من أجود أنواع الحديد الصلب المصري، بتصميم عملي يضمن توزيع حراري ممتاز وسهولة في الاستخدام."
        features={[
          "حديد صلب مصري عالي الجودة",
          "مقاس مدمج مناسب للشرفات والحدائق الصغيرة",
          "توزيع حراري مثالي ومتساوي",
          "تصميم سهل التنظيف والصيانة",
          "متانة تدوم لسنوات طويلة"
        ]}
        image="/images/grill-40x30.jpg"
        whatsappSize="30x40"
      />
      
      <ProductCard
        name="شواية ستيلورا (4060)"
        nameEn="Steelora Grill 4060"
        size="4060"
        sizeLabel="40×60 سم"
        description="شواية احترافية كبيرة الحجم للحفلات والتجمعات الكبيرة. مصنوعة بمعايير هندسية عالية من الحديد الصلب الثقيل، توفر مساحة شواء واسعة مع أداء حراري فائق."
        features={[
          "حديد صلب ثقيل بسماكة مضاعفة",
          "مساحة شواء واسعة للتجمعات الكبيرة",
          "أداء حراري فائق وتوزيع متساوي",
          "مثالية للمطاعم والاستخدام التجاري",
          "قاعدة ثابتة مقاومة للرياح"
        ]}
        image="/images/grill-60x40.jpg"
        whatsappSize="40x60"
      />
    </div>
  </div>
</section>
