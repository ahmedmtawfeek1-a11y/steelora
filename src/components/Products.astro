---
// Products.astro — Products section with two premium grills, fully localized
import ProductCard from './ProductCard.astro';
import { translations, type Lang } from '../utils/i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'ar' } = Astro.props;
const t = translations[lang];
---

<section id="products" class="relative py-20 sm:py-28 bg-gradient-to-b from-primary via-slate-900 to-primary overflow-hidden">
  <!-- Decorative background -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 start-1/4 w-96 h-96 bg-accent-light rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 end-1/4 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
  </div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-accent/10 border border-accent/20 rounded-full text-accent-light text-sm font-medium mb-4">{t.productsBadge}</span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-white mb-4">
        {t.productsTitle}
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        {t.productsDesc}
      </p>
      <!-- Decorative line -->
      <div class="mt-6 flex items-center justify-center gap-2">
        <div class="w-12 h-0.5 bg-accent/30"></div>
        <div class="w-3 h-3 border-2 border-accent rotate-45"></div>
        <div class="w-12 h-0.5 bg-accent/30"></div>
      </div>
    </div>
    
    <!-- Products Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      <!-- Product 1 (40x30 cm) -->
      <ProductCard
        name={t.p1Name}
        sizeLabel={lang === 'ar' ? '٤٠×٣٠ سم' : '40x30 cm'}
        description={t.p1Desc}
        features={t.p1Features}
        image="/images/grill-40x30.jpg"
        whatsappLink={t.p1WhatsappLink}
        orderLabel={t.orderNow}
      />
      
      <!-- Product 2 (60x40 cm) -->
      <ProductCard
        name={t.p2Name}
        sizeLabel={lang === 'ar' ? '٦٠×٤٠ سم' : '60x40 cm'}
        description={t.p2Desc}
        features={t.p2Features}
        image="/images/grill-60x40.jpg"
        whatsappLink={t.p2WhatsappLink}
        orderLabel={t.orderNow}
      />
    </div>
  </div>
</section>
