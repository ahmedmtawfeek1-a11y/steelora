---
// Footer.astro — CRITICAL: Dark Mode & Neon Cyber-Industrial Look, fully localized
import { translations, type Lang } from '../utils/i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'ar' } = Astro.props;
const t = translations[lang];
---

<footer class="relative bg-[#0a0a0c] overflow-hidden">
  <!-- Circuit board / grid pattern background -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(56,189,248,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(56,189,248,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>
  
  <!-- Top neon glow line -->
  <div class="h-px bg-gradient-to-r from-transparent via-cyan-400 to-transparent opacity-40"></div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      
      <!-- Column 1: Logo & Brand -->
      <div class="text-center md:text-start">
        <!-- Neon Logo -->
        <a href="#home" class="inline-flex items-center gap-3 group">
          <div class="inline-block bg-slate-100/95 backdrop-blur-sm p-2 rounded-xl border border-white/20 hover:bg-white transition-all duration-300 shadow-lg shadow-black/10">
            <img src="/logo_icon.png" alt="Steelora Icon" class="h-9 w-9 object-contain" />
          </div>
          <span class="text-2xl font-black tracking-wide text-accent-light text-shadow-neon-orange">
            Steelora
          </span>
        </a>
        <p class="text-gray-500 mt-4 text-sm leading-relaxed max-w-xs mx-auto md:mx-0">
          {t.footerSlogan}
        </p>
        
        <!-- Social Media Icons -->
        <div class="flex items-center justify-center md:justify-start gap-4 mt-6">
          <!-- Twitter/X -->
          <a href="#" aria-label="Twitter" class="group/icon w-10 h-10 rounded-lg bg-slate-800/50 border border-slate-700/50 flex items-center justify-center hover:border-cyan-400/50 transition-all duration-300 hover:bg-cyan-400/5">
            <svg class="w-4 h-4 text-gray-500 group-hover/icon:text-cyan-400 transition-colors duration-300" style="filter: drop-shadow(0 0 0px transparent);" onmouseover="this.style.filter='drop-shadow(0 0 6px #22d3ee)'" onmouseout="this.style.filter='drop-shadow(0 0 0px transparent)'" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a href="#" aria-label="Instagram" class="group/icon w-10 h-10 rounded-lg bg-slate-800/50 border border-slate-700/50 flex items-center justify-center hover:border-cyan-400/50 transition-all duration-300 hover:bg-cyan-400/5">
            <svg class="w-4 h-4 text-gray-500 group-hover/icon:text-cyan-400 transition-colors duration-300" style="filter: drop-shadow(0 0 0px transparent);" onmouseover="this.style.filter='drop-shadow(0 0 6px #22d3ee)'" onmouseout="this.style.filter='drop-shadow(0 0 0px transparent)'" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <!-- WhatsApp -->
          <a href="https://wa.me/201012345678" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="group/icon w-10 h-10 rounded-lg bg-slate-800/50 border border-slate-700/50 flex items-center justify-center hover:border-cyan-400/50 transition-all duration-300 hover:bg-cyan-400/5">
            <svg class="w-4 h-4 text-gray-500 group-hover/icon:text-cyan-400 transition-colors duration-300" style="filter: drop-shadow(0 0 0px transparent);" onmouseover="this.style.filter='drop-shadow(0 0 6px #22d3ee)'" onmouseout="this.style.filter='drop-shadow(0 0 0px transparent)'" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Column 2: Quick Links -->
      <div class="text-center md:text-start">
        <h4 class="text-white font-bold text-lg mb-6 flex items-center justify-center md:justify-start gap-2">
          <span class="w-2 h-2 bg-cyan-400 rounded-full shadow-neon-cyan-sm"></span>
          {t.quickLinks}
        </h4>
        <ul class="space-y-3">
          <li>
            <a href="#home" class="text-gray-500 hover:text-cyan-400 hover:text-shadow-neon-cyan transition-all duration-300 text-sm inline-block hover:translate-x-1.5 rtl:hover:-translate-x-1.5">{t.home}</a>
          </li>
          <li>
            <a href="#products" class="text-gray-500 hover:text-cyan-400 hover:text-shadow-neon-cyan transition-all duration-300 text-sm inline-block hover:translate-x-1.5 rtl:hover:-translate-x-1.5">{t.products}</a>
          </li>
          <li>
            <a href="#about" class="text-gray-500 hover:text-cyan-400 hover:text-shadow-neon-cyan transition-all duration-300 text-sm inline-block hover:translate-x-1.5 rtl:hover:-translate-x-1.5">{t.about}</a>
          </li>
          <li>
            <a href="#contact" class="text-gray-500 hover:text-cyan-400 hover:text-shadow-neon-cyan transition-all duration-300 text-sm inline-block hover:translate-x-1.5 rtl:hover:-translate-x-1.5">{t.contact}</a>
          </li>
        </ul>
      </div>
      
      <!-- Column 3: Contact Info -->
      <div class="text-center md:text-start">
        <h4 class="text-white font-bold text-lg mb-6 flex items-center justify-center md:justify-start gap-2">
          <span class="w-2 h-2 bg-cyan-400 rounded-full shadow-neon-cyan-sm"></span>
          {t.contact}
        </h4>
        <ul class="space-y-4">
          <li class="flex items-center justify-center md:justify-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-slate-800/50 border border-slate-700/50 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <a href="tel:+201012345678" class="text-gray-500 hover:text-cyan-400 transition-colors duration-300 text-sm" dir="ltr">+20 101 234 5678</a>
          </li>
          <li class="flex items-center justify-center md:justify-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-slate-800/50 border border-slate-700/50 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <a href="mailto:info@steelora.com" class="text-gray-500 hover:text-cyan-400 transition-colors duration-300 text-sm" dir="ltr">info@steelora.com</a>
          </li>
          <li class="flex items-center justify-center md:justify-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-slate-800/50 border border-slate-700/50 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <span class="text-gray-500 text-sm">{t.cairoEgypt}</span>
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Bottom bar with neon separator -->
    <div class="mt-12 pt-8 border-t border-slate-800/80">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-gray-600 text-sm">
          © {new Date().getFullYear()} <span class="text-accent/70 text-shadow-neon-orange">STEELORA</span> — {t.allRightsReserved}
        </p>
        <p class="text-gray-700 text-xs">
          {t.madeWithFire}
        </p>
      </div>
    </div>
  </div>
</footer>
