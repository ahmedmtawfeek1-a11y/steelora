---
// Header.astro — Sticky header with backdrop blur, language switcher, and responsive mobile menu
import { translations, type Lang } from '../utils/i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'ar' } = Astro.props;
const t = translations[lang];
---

<header id="main-header" class="fixed top-0 right-0 left-0 z-50 transition-all duration-300 bg-transparent">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-18 sm:h-20">
      
      <!-- Logo -->
      <a href="#home" class="flex items-center gap-3 group">
        <div class="bg-slate-100/95 backdrop-blur-sm p-1.5 sm:p-2 rounded-xl border border-white/20 hover:bg-white transition-all duration-300 shadow-lg shadow-black/10 flex items-center justify-center">
          <img src="/logo_icon.png" alt="Steelora Icon" class="h-8 sm:h-9 w-8 sm:w-9 object-contain" />
        </div>
        <span class="text-xl sm:text-2xl font-black tracking-wide text-white">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">S</span>teelora
        </span>
      </a>
      
      <!-- Desktop Navigation & Lang Switcher -->
      <div class="hidden md:flex items-center gap-6 lg:gap-8">
        <a href="#home" class="nav-link text-gray-300 hover:text-accent-light transition-colors duration-300 text-sm font-medium">{t.home}</a>
        <a href="#products" class="nav-link text-gray-300 hover:text-accent-light transition-colors duration-300 text-sm font-medium">{t.products}</a>
        <a href="#about" class="nav-link text-gray-300 hover:text-accent-light transition-colors duration-300 text-sm font-medium">{t.about}</a>
        <a href="#contact" class="nav-link text-gray-300 hover:text-accent-light transition-colors duration-300 text-sm font-medium px-5 py-2 rounded-full border border-accent/50 hover:bg-accent/10">{t.contact}</a>
        
        <!-- Language Switcher Button -->
        <a 
          href={t.langSwitchUrl} 
          class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-slate-700 bg-slate-800/50 hover:bg-slate-700/50 hover:border-accent/50 text-gray-300 hover:text-accent-light text-sm font-semibold transition-all duration-300"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 002 2h2m4-3.5a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {t.langSwitch}
        </a>
      </div>
      
      <!-- Mobile Controls (Menu Button & Lang Toggle next to it) -->
      <div class="flex items-center gap-4 md:hidden">
        <!-- Language Switcher Button for Mobile -->
        <a 
          href={t.langSwitchUrl} 
          class="flex items-center gap-1 px-2.5 py-1.5 rounded-lg border border-slate-700 bg-slate-800/40 text-gray-300 text-xs font-bold hover:border-accent/40"
        >
          {t.langSwitch}
        </a>
        
        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="flex flex-col gap-1.5 p-2 group" aria-label="Menu">
          <span class="block w-6 h-0.5 bg-white transition-all duration-300 origin-center group-[.active]:rotate-45 group-[.active]:translate-y-2"></span>
          <span class="block w-6 h-0.5 bg-white transition-all duration-300 group-[.active]:opacity-0"></span>
          <span class="block w-4 h-0.5 bg-accent-light transition-all duration-300 origin-center group-[.active]:w-6 group-[.active]:-rotate-45 group-[.active]:-translate-y-2"></span>
        </button>
      </div>
    </div>
  </nav>
  
  <!-- Mobile Menu Overlay (Vertical slide/fade) -->
  <div id="mobile-menu" class="md:hidden fixed inset-x-0 top-18 bg-slate-950/95 backdrop-blur-xl opacity-0 pointer-events-none -translate-y-4 transition-all duration-300 ease-in-out z-40 border-b border-slate-800/50">
    <div class="flex flex-col items-center justify-center py-12 gap-6">
      <a href="#home" class="mobile-nav-link text-xl font-semibold text-white hover:text-accent-light transition-colors duration-300">{t.home}</a>
      <a href="#products" class="mobile-nav-link text-xl font-semibold text-white hover:text-accent-light transition-colors duration-300">{t.products}</a>
      <a href="#about" class="mobile-nav-link text-xl font-semibold text-white hover:text-accent-light transition-colors duration-300">{t.about}</a>
      <a href="#contact" class="mobile-nav-link text-xl font-semibold text-accent-light hover:text-amber-300 transition-colors duration-300 px-8 py-2.5 rounded-full border border-accent-light/50 hover:bg-accent-light/10">{t.contact}</a>
    </div>
  </div>
</header>

<script>
  // Header scroll effect
  const header = document.getElementById('main-header');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('bg-slate-900/90', 'backdrop-blur-md', 'shadow-lg', 'shadow-black/20');
      header?.classList.remove('bg-transparent');
    } else {
      header?.classList.remove('bg-slate-900/90', 'backdrop-blur-md', 'shadow-lg', 'shadow-black/20');
      header?.classList.add('bg-transparent');
    }
  });
  
  // Mobile menu toggle
  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenuBtn.classList.toggle('active');
    if (mobileMenu?.classList.contains('opacity-0')) {
      mobileMenu.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-4');
      mobileMenu.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu?.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
      mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
      document.body.style.overflow = '';
    }
  });
  
  // Close mobile menu on link click
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenuBtn?.classList.remove('active');
      mobileMenu?.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
      mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
      document.body.style.overflow = '';
    });
  });
</script>
