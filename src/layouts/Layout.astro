---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'STEELORA | شوايات ستيلورا — صناعة مصرية بجودة عالمية',
  description = 'ستيلورا — شوايات فاخرة من الحديد الصلب المصري. تصميم هندسي متقن، توزيع حراري مثالي، ومتانة تدوم لسنوات. اطلب شوايتك الآن!'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#111827" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ar_EG" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Cairo -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="font-cairo antialiased">
    <slot />
  </body>
</html>
